  (text "Legacy note page only. Open remote.kicad_sch as the KiCad project root." (at 35 25.4 0) (effects (font (size 1.27 1.27))) (uuid "f4c7191d-7dc7-47f0-aea8-89d7d9d94021"))
  (text "Active default: STM8L051F3P6 MCU + IRLML2502 low-side NMOS + CR2032" (at 35 38.1 0) (effects (font (size 1.27 1.27))) (uuid "f4c7191d-7dc7-47f0-aea8-89d7d9d94022"))
  (text "Code/schematic pin map: PA0=IR_GPIO/SWIM, PB0=KEY1_N, PB1=KEY2_N, PD0=KEY3_N, PC1=DBG_STRAP" (at 35 50.8 0) (effects (font (size 1.27 1.27))) (uuid "f4c7191d-7dc7-47f0-aea8-89d7d9d94023"))
  (text "Sheets/blocks: MCU+Keys+Debug, Power+IR Driver; nets: VDD_MCU, GND, IR_GPIO, IR_GATE, KEY1_N, KEY2_N, KEY3_N" (at 35 63.5 0) (effects (font (size 1.27 1.27))) (uuid "f4c7191d-7dc7-47f0-aea8-89d7d9d94024"))
